{
    "name": "nicol/wf-price-checker",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "symfony/cache": "^7.3",
        "symfony/config": "^7.3",
        "symfony/console": "^7.3",
        "symfony/dependency-injection": "^7.3",
        "symfony/dotenv": "^7.3",
        "symfony/error-handler": "^7.3",
        "symfony/framework-bundle": "^7.3",
        "symfony/http-client": "^7.3",
        "symfony/runtime": "^7.3",
        "symfony/twig-bundle": "^7.3",
        "symfony/yaml": "^7.3",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "symfony/var-dumper": "^7.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"is_dir('var/cache') || mkdir('var/cache', 0777, true);\"",
            "@php -r \"is_dir('var/log') || mkdir('var/log', 0777, true);\""
        ],
        "post-update-cmd": [
            "@php -r \"is_dir('var/cache') || mkdir('var/cache', 0777, true);\"",
            "@php -r \"is_dir('var/log') || mkdir('var/log', 0777, true);\""
        ]
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "extra": {
        "public-dir": "public"
    }
}
